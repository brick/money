{
    "name": "brick/money",
    "description": "Money and currency library",
    "type": "library",
    "keywords": [
        "Brick",
        "Money",
        "Currency"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "brick/math": "~0.15.0 || ~0.16.0 || ~0.17.0"
    },
    "require-dev": {
        "ext-dom": "*",
        "ext-pdo": "*",
        "brick/varexporter": "0.7.0",
        "phpstan/phpstan": "2.1.40",
        "phpunit/phpunit": "^11.0"
    },
    "suggest": {
        "ext-intl": "Required to format Money objects"
    },
    "autoload": {
        "psr-4": {
            "Brick\\Money\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Brick\\Money\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
